}

def resource -params 1 %{
  eval %sh{
    file=$(mktemp)
    cat "$1" |
      sed 's/^def /def -override /'                       |
      sed 's/^define-command /def -override /'            |
      sed 's/^addhl /addhl -override /'                   |
      sed 's/^add-highlighter /addhl -override /'         |
      sed 's/^provide-module / provide-module -override/' |
      sed 's/^require-module /# require-module/'          |
      sed 's/^declare-user-mode /# declare-user-mode/'    |
      cat > "$file"
    printf %s "
      source $file
      nop %sh{
          rm $file
      }
    "
  }
  echo Reloaded %arg{1}
}

rmhooks global reload-kak
hook -group reload-kak global BufWritePost (.*kakrc|.*\.kak) %{
   resource %val{hook_param}
}
