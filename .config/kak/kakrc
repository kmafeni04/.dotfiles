define-command _clipboard-paste -hidden -params 1 %{
  eval -save-regs c %sh{
    content=$(
      ~/.scripts/clip.sh out                   |
      sed 's/</#:____lt____:#/g'               |
      sed 's/>/#:____gt____:#/g'               |
      sed -E 's/#:____([a-z]{2})____:#/<\1>/g' |
      sed 's/;/<semicolon>/g'                  |
      sed 's/$/<ret>/g;'                       |
      sed 's/ /<space>/g'                      |
      sed 's/\t/<tab>/g'                       |
      sed ':a;N;$!ba;s/\n//g'                  |
      sed 's/<ret>$//'
    )
    echo "exec -draft o$content<esc>x_<dquote>cdx<a-d>"
    echo "exec <dquote>c$1"
  }
}
