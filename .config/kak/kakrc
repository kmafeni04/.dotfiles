#### hooks ####
hook global BufCreate .* %{
  expandtab
}

declare-option -docstring "Name of the git branch holding the current buffer" \
  str modeline_git_branch

declare-option -docstring "List of currently open buffers" \
  str modeline_buflist

declare-option -docstring "Curretly buffer filetype" \
    str modeline_filetype

hook global WinCreate .* %{
  hook window ModeChange pop:insert:normal %{
    eval %sh{
      [ "$kak_modified" = true ] && echo "write"
    }
  }
  hook window NormalIdle .* %{

    try %{
      eval %sh{
        [[ "$kak_buffile" =~ \*.+\* ]] && echo 'set window modeline_git_branch NONE' && exit
        branch=$(cd "$(dirname "${kak_buffile}")" && git rev-parse --abbrev-ref HEAD 2>/dev/null)
        [ -n "$branch" ] && printf 'set window modeline_git_branch " %%{%s}"' "$branch" && exit
        echo 'set window modeline_git_branch NONE'
      }
    }

    set-option global modeline_buflist ""
    evaluate-commands -no-hooks -buffer * %{
      set-option -add global modeline_buflist "%val{bufname} "
    }

    try %{
      eval %sh{
        filetype="$kak_opt_filetype"
        [ -n "$filetype" ] && echo "set window modeline_filetype $filetype" && exit
        [[ "$kak_bufname" =~ \*.+\* ]] && echo "set window modeline_filetype 'kak-star'" && exit
        echo "set window modeline_filetype 'txt'"
      }
    }
  }
}

declare-option -docstring "Current mode" \
  str modeline_mode 'NORMAL'

hook global ModeChange .* %{
  eval %sh{
    new_mode=$(echo $kak_hook_param | cut -d ':' -f 3 | sed 's/.*/\U&/' 2>/dev/null)
    printf 'set window modeline_mode "%%{%s}"' "${new_mode}"
  }
}

