define-command clipboard-paste-before %{
  eval %sh{
    echo "exec i$(~/.scripts/clip.sh out | sed 's/<\(.*\)>/<lt>\1<gt>/g' | sed 's/ /<space>/g')"
  }
}
define-command clipboard-paste-after %{
  eval %sh{
    echo "exec a$(~/.scripts/clip.sh out | sed 's/<\(.*\)>/<lt>\1<gt>/g' | sed 's/ /<space>/g')"
  }
}
define-command clipboard-paste-replace %{
  eval %sh{
    echo "exec di$(~/.scripts/clip.sh out | sed 's/<\(.*\)>/<lt>\1<gt>/g' | sed 's/ /<space>/g')"
  }
}
map global user <p> ':clipboard-paste-before<ret><esc>' -docstring 'Paste clipboard to buffer before cursor'
map global user <P> ':clipboard-paste-after<ret><esc>' -docstring 'Paste clipboard to buffer after cursor'
