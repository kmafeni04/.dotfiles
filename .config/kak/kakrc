#### hooks ####
hook global BufCreate .* %{
  expandtab
}

declare-option -docstring "name of the git branch holding the current buffer" \
  str git_branch

hook global WinCreate /.* %{
  hook window NormalIdle .* %{
    eval %sh{
      branch=$(cd "$(dirname "${kak_buffile}")" && git rev-parse --abbrev-ref HEAD 2>/dev/null)
      if [ -n "${branch}" ]; then
        printf 'set window git_branch " %%{%s}"' "${branch}"
      fi
    }
  }

  hook buffer NormalIdle .* %{
    try %{
      eval %sh{
        [ "$kak_modified" = true ] && echo "write"

        # modified=""
        # [ "$kak_modified" = true ] && modified="[+]"
        bufname=$(echo $kak_bufname | sed 's/[.\*+?[^$()|{}]/\\&/g; s/\//\\\//g;')
        buflist=$(echo $kak_buflist | sed 's/[.\*+?[^$()|{}]/\\&/g; s/\//\\\//g;')
        buffers=$(echo "$buflist" | sed "s/\\\\//g" | sed 's/ *\*debug\* *//' | sed "s/\($bufname\)/>\1/")
        printf 'set buffer buffers "%%{%s}"' "${buffers}"

      }
    }
  }
}

declare-option -docstring "Current mode" \
