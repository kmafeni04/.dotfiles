#### hooks ####
hook global BufCreate .* %{
  expandtab
}

declare-option -docstring "name of the git branch holding the current buffer" \
  str git_branch

hook global WinCreate /.* %{
  hook window NormalIdle .* %{ evaluate-commands %sh{
    branch=$(cd "$(dirname "${kak_buffile}")" && git rev-parse--abbrev-ref HEAD 2>/dev/null)
    if  [ -n "${branch}" ]; then
      printf 'set window git_branch " %%{%s}|"'"${branch}"
    fi
  }}
 }

declare-option -docstring "Current mode" \
  str mode 'NORMAL'

hook global ModeChange .* %{
  eval %sh{
    new_mode=$(echo $kak_hook_param | cut -d ':' -f 3 | sed 's/.*/\U&/' 2>/dev/null)
    printf 'set window mode "%%{%s}"' "${new_mode}"
  }
}

declare-option -docstring "Curretly open buffers"\
    str buffers

hook global WinCreate .* %{
  hook buffer NormalIdle .* %{
    try %{
      eval %sh{
        name=$(echo $kak_bufname | sed 's/[.\*+?[^$()|{}]/\\&/g; s/\//\\\//g;')
        buflist=$(echo $kak_buflist | sed 's/[.\*+?[^$()|{}]/\\&/g; s/\//\\\//g;')
        buffers=$(echo "$buflist" | sed "s/\\\\//g" | sed 's/ *\*debug\* *//' | sed "s/\($name\)/\[*\]\1/")
        printf 'set buffer buffers "%%{%s}"' "${buffers}"
      }

      eval %sh{ [ "$kak_modified" = false ] && printf 'fail' }
      write
      echo "%val{bufname} written"
    }
  }
}

set global modelinefmt '%opt{git_branch} %opt{buffers} | %val{bufname} | %val{cursor_line}:%val{cursor_char_column} | %val{modified} | %opt{mode} | {{mode_info}} |'

hook global InsertCompletionShow .* %{
  try %{
    # this command temporarily removes cursors preceded by whitespace;
    # if there are no cursors left, it raises an error, does not
    # continue to execute the mapping commands, and the error is eaten
    # by the `try` command so no warning appears.
    execute-keys -draft 'h<a-K>\h<ret>'
    map window insert <tab> <c-n>
    map window insert <s-tab> <c-p>
    hook -once -always window InsertCompletionHide .* %{
      unmap window insert <tab> <c-n>
      unmap window insert <s-tab> <c-p>
    }
  }
}

