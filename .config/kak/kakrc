define-command _clipboard-paste -hidden -params 1 %{
  eval %sh{
    content=$(
      ~/.scripts/clip.sh out                     \
      | sed 's/</#:____lt____:#/g'               \
      | sed 's/>/#:____gt____:#/g'               \
      | sed -E 's/#:____([a-z]{2})____:#/<\1>/g' \
      | sed 's/;/<semicolon>/g'                  \
      | sed 's/$/<ret>/g;'                       \
      | sed 's/ /<space>/g'                      \
      | sed 's/\t/<tab>/g'                       \
      | sed ':a;N;$!ba;s/\n//g'                  \
      | sed 's/<ret>$//'                         \
    )
    echo "exec $1${content}"
  }
}
define-command clipboard-paste-before %{
  _clipboard-paste "i"
}
define-command clipboard-paste-after %{
  _clipboard-paste "a"
}
define-command clipboard-paste-replace %{
  _clipboard-paste "di"
}
map global user <p> ':clipboard-paste-before<ret><esc>' -docstring 'Paste clipboard to buffer before cursor'
