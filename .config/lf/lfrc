map D :drag-from; full-clear
map P paste-img

map d delete
map <delete> delete
map u ${{
  echo
  trash-restore
  clear
}}
map p :paste; full-clear
map x cut
map y copy

map R rename-in-editor

map e open
map o open
map <enter> open
map O push :open-with<space>

map <c-r> %{{
  lf -remote "send $id reload"
  lf -remote "send $id redraw"
  lf -remote "send $id source '~/.config/lf/lfrc'"
  sleep 0.2
  echo "Config Reloaded"
}}

map ca copy-absolute-path
map cn copy-name-w-ext
map ce copy-name-wo-ext
map cp copy-parent-dir-path
map ci copy-image

map cs check-storage

# show the result of execution of previous commands
map ` !true

